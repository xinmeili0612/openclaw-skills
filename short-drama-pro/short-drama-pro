        return 1
    fi
    
    print_header "👤 第3步：角色开发中..."
    
    local theme=$(grep -o '"theme": "[^"]*"' "$config_file" | cut -d'"' -f4)
    local overseas=$(grep -o '"overseas": [^,]*' "$config_file" | cut -d' ' -f2)
    
    # 生成角色档案
    local characters_file="$PROJECT_DIR/角色档案.md"
    
    cat > "$characters_file" << EOF
# 《${theme}》角色档案

## 🎭 主要角色

### 主角：苏清月（女，18岁）
**公开身份**：贫民窟学霸，普通高中生
**真实身份**：苏氏集团真千金

**外貌特征**：
- 清秀但衣着朴素，常年穿洗得发白的校服
- 眼神清澈坚定，有一种不服输的倔强
- 手指有长期写字留下的茧子

**性格特征**：
- **表面**：冷静、内向、不善言辞
- **内在**：聪明、坚韧、善良、有原则
- **矛盾**：渴望亲情但又保持距离，相信知识改变命运

**核心动机**：
1. 治好养母的病
2. 证明自己的价值
3. 获得真正的亲情认可
4. 用知识改变命运

**爽点功能**：
- 学霸实力打脸看不起她的人
- 从底层逆袭的励志感
- 亲情线的感动和共鸣
- 爱情线的甜蜜和守护

**成长弧线**：
贫民窟自卑女孩 → 自信学霸 → 豪门千金 → 独立女性

###